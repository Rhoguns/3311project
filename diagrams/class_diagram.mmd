classDiagram
    direction TB


    %% ACTORS & CORE DOMAIN ENTITIES
    
    class Admin {
        <<singleton>>
        -instance: Admin
        +getInstance(): Admin$
        +configurePolicy(command: PolicyCommand): void
        +reviewConsultant(consultant: Consultant): boolean
    }

    class Client {
        -clientId: String
        -name: String
        -email: String
        +browseServices(): List~Service~
        +requestBooking(consultant: Consultant, slot: AvailabilitySlot): Booking
        +cancelBooking(booking: Booking): void
        +viewBookingHistory(): List~Booking~
        +managePaymentMethods(): void
        +processPayment(booking: Booking, method: PaymentMethod): Payment
        +viewPaymentHistory(): List~Payment~
    }

    class Consultant {
        -consultantId: String
        -name: String
        -email: String
        -status: String
        +register(): void
        +manageAvailability(slots: List~AvailabilitySlot~): void
        +acceptBooking(booking: Booking): void
        +rejectBooking(booking: Booking): void
        +completeBooking(booking: Booking): void
    }

    class Service {
        -serviceId: String
        -type: String
        -duration: int
        -basePrice: double
    }

    class AvailabilitySlot {
        -slotId: String
        -date: Date
        -startTime: String
        -endTime: String
        -isAvailable: boolean
        +markAvailable(): void
        +markUnavailable(): void
    }


    %% BOOKING SUBSYSTEM (State Pattern)
    
    class BookingService {
        +createBooking(client: Client, consultant: Consultant): Booking
        +updateState(booking: Booking, state: BookingState): void
    }

    class Booking {
        -bookingId: String
        -totalAmount: double
        +getState(): BookingState
        +setState(state: BookingState): void
    }

    class BookingState {
        <<interface>>
        +handle(booking: Booking): void
    }
    class RequestedState { +handle(booking: Booking) }
    class ConfirmedState { +handle(booking: Booking) }
    class PendingPaymentState { +handle(booking: Booking) }
    class PaidState { +handle(booking: Booking) }
    class CompletedState { +handle(booking: Booking) }
    class RejectedState { +handle(booking: Booking) }
    class CancelledState { +handle(booking: Booking) }

    %% PAYMENT SUBSYSTEM (Strategy & State)

    class Payment {
        -paymentId: String
        -amount: double
        -transactionDate: Date
        +process(): void
        +generateConfirmation(): String
        +setState(state: PaymentState): void
    }

    class PaymentState {
        <<interface>>
        +handle(payment: Payment): void
        +getStatus(): String
    }
    class PaymentPendingState { +handle(payment: Payment) }
    class PaymentSuccessfulState { +handle(payment: Payment) }
    class PaymentFailedState { +handle(payment: Payment) }
    class PaymentRefundedState { +handle(payment: Payment) }

    class PaymentMethod {
        <<abstract>>
        -methodId: String
        -encryptedDetails: String
        +validate()* boolean
    }
    class CreditCard { +validate(): boolean }
    class DebitCard { +validate(): boolean }
    class PayPalAccount { +validate(): boolean }
    class BankAccount { +validate(): boolean }

    %% POLICY SUBSYSTEM (Command Pattern)

    class PolicyCommand {
        <<interface>>
        +update(): boolean
    }
    class CancellationPolicyCommand {
        -policy: CancellationPolicy
        +update(): boolean
    }
    class PricingPolicyCommand {
        -policy: PricingPolicy
        +update(): boolean
    }
    class RefundPolicyCommand {
        -policy: RefundPolicy
        +update(): boolean
    }
    class NotificationPolicyCommand {
        -policy: NotificationPolicy
        +update(): boolean
    }

    class CancellationPolicy {
        -cancellationWindowTime: int
        -change(): void
        +applyChange(): void
        +getCancellationPolicy(): int
    }
    class PricingPolicy {
        -minPrice: double
        -maxPrice: double
        -change(): void
        +applyChange(): void
        +getMinPrice(): double
        +getMaxPrice(): double
    }
    class RefundPolicy {
        -refundWindowTime: int
        -change(): void
        +applyChange(): void
        +getRefundPolicy(): int
    }
    class NotificationPolicy {
        -enableNotifications: boolean
        -change(): void
        +applyChange(): void
        +getNotificationPolicy(): boolean
    }


    %% User & Admin Associations

    Admin "1" ..> "0..*" Consultant : reviews
    Admin "1" ..> "0..*" PolicyCommand : executes
    
    Client "1" --> "0..*" Booking : requests
    Client "1" *-- "0..*" Payment : makes
    Client "1" *-- "0..*" PaymentMethod : saves
    Client --> Service : browses
    
    Consultant "1" *-- "0..*" AvailabilitySlot : manages
    Consultant "1" --> "1..*" Service : offers
    Consultant "1" --> "0..*" Booking : responds to

    %% Booking Structure

    BookingService ..> Booking : controls
    Booking "1" o--> "1" BookingState : current state
    Booking "1" -- "0..1" Payment : requires

    BookingState <|.. RequestedState
    BookingState <|.. ConfirmedState
    BookingState <|.. PendingPaymentState
    BookingState <|.. PaidState
    BookingState <|.. CompletedState
    BookingState <|.. RejectedState
    BookingState <|.. CancelledState

    %% Payment Structure

    Payment "1" --> "1" PaymentMethod : uses
    Payment "1" o--> "1" PaymentState : tracking
    
    PaymentState <|.. PaymentPendingState
    PaymentState <|.. PaymentSuccessfulState
    PaymentState <|.. PaymentFailedState
    PaymentState <|.. PaymentRefundedState

    PaymentMethod <|-- CreditCard
    PaymentMethod <|-- DebitCard
    PaymentMethod <|-- PayPalAccount
    PaymentMethod <|-- BankAccount

    %% Policy Structure

    PolicyCommand <|.. CancellationPolicyCommand
    PolicyCommand <|.. PricingPolicyCommand
    PolicyCommand <|.. RefundPolicyCommand
    PolicyCommand <|.. NotificationPolicyCommand

    CancellationPolicyCommand *-- CancellationPolicy
    PricingPolicyCommand *-- PricingPolicy
    RefundPolicyCommand *-- RefundPolicy
    NotificationPolicyCommand *-- NotificationPolicy